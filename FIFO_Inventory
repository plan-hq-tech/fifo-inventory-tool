                              <td className="px-4 py-3">{fmt(r.yDiscardAmt)}</td>
                              <td className="px-4 py-3"><span className="bg-yellow-50 px-2 py-1 rounded">{fmt(r.currentSaleQty)}</span></td>
                              <td className="px-4 py-3">{fmt(r.currentSaleAmt)}</td>
                              <td className="px-4 py-3"><span className="bg-yellow-100 px-2 py-1 rounded">{fmt(r.currentDiscardQty)}</span></td>
                              <td className="px-4 py-3">{fmt(r.currentDiscardAmt)}</td>
