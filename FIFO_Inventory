                              <td className={`px-4 py-3 ${r.shortageAmt > 0 ? 'text-red-600 font-semibold' : ''}`}>{fmt(r.shortageAmt)}</td>
                              <td className="px-4 py-3 text-xs text-slate-600">{[...new Set(r.rowFlags)].join(', ')}</td>
                            </tr>
                          );
