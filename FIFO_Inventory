                      </thead>
                      <tbody>
                        {processed.anomalies.map((r, idx) => (
                          <tr key={`${r.date}-${r.itemGroup}-${idx}`} className="border-t bg-white">
                            <td className="px-4 py-3">{r.date}</td>
                            <td className="px-4 py-3 font-medium">{r.itemGroup}</td>
                            <td className="px-4 py-3 text-red-600 font-semibold">{fmt(r.shortageQty)}</td>
                            <td className="px-4 py-3 text-red-600 font-semibold">{fmt(r.shortageAmt)}</td>
                            <td className="px-4 py-3 text-slate-700">{r.flags}</td>
                          </tr>
